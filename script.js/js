// ====== INTRO / LOGO ======
window.addEventListener("load", () => {
  const intro = document.getElementById("intro");
  if (intro) {
    setTimeout(() => {
      intro.style.display = "none";
    }, 2800);
  }
});


// ====== MUSIC TOGGLE ======
const musicBtn = document.getElementById("music-toggle");
const bgMusic = document.getElementById("bg-music");

if (musicBtn && bgMusic) {
  try { bgMusic.pause(); } catch (e) {}

  musicBtn.addEventListener("click", () => {

    if (bgMusic.paused) {

      bgMusic.play();
      musicBtn.textContent = "Pausar Música de Fundo";
      musicBtn.classList.add("playing");

    } else {

      bgMusic.pause();
      musicBtn.textContent = "Tocar Música de Fundo";
      musicBtn.classList.remove("playing");

    }

  });
}


// ====== PARTICLES NOVAS ======
const particlesContainer = document.getElementById("particles-new");
const numSquares = 60;

if (particlesContainer) {

  for (let i = 0; i < numSquares; i++) {

    const square = document.createElement("div");
    square.classList.add("square");

    if (Math.random() > 0.7) {
      square.classList.add("white");
    }

    square.style.left = `${Math.random() * 100}vw`;
    square.style.top = `${Math.random() * -20}vh`;

    square.style.animationDuration = `${Math.random() * 5 + 6}s`;
    square.style.animationDelay = `${Math.random() * 5}s`;

    particlesContainer.appendChild(square);

  }

}


// ====== ABRIR / FECHAR COMENTÁRIOS (DISQUS REAL) ======
document.querySelectorAll(".open-comments-btn").forEach(btn => {

  btn.addEventListener("click", () => {

    const postId = btn.dataset.identifier;
    const comments = document.getElementById(`comments-${postId}`);

    if (!comments) return;


    // ===== FECHAR COMENTÁRIOS =====
    if (btn.classList.contains("open")) {

      comments.style.display = "none";

      btn.classList.remove("open");
      btn.textContent = "Abrir comentários";

      return;
    }


    // ===== ABRIR COMENTÁRIOS =====
    comments.style.display = "block";

    btn.classList.add("open");
    btn.textContent = "Fechar comentários";


    // se já carregou antes, não recarrega
    if (comments.dataset.loaded === "true") return;


    comments.innerHTML = `<em id="loading-${postId}">Carregando comentários...</em>`;


    window.disqus_config = function () {
      this.page.url = window.location.href + "#" + postId;
      this.page.identifier = postId;
    };


    if (!window.DISQUS) {

      const d = document;
      const s = d.createElement("script");

      s.src = "https://codinaproject.disqus.com/embed.js";
      s.setAttribute("data-timestamp", +new Date());

      s.onload = () => {

        const loading = document.getElementById(`loading-${postId}`);
        if (loading) loading.remove();

        comments.dataset.loaded = "true";

      };

      (d.head || d.body).appendChild(s);

    } else {

      DISQUS.reset({

        reload: true,

        config: function () {

          this.page.identifier = postId;
          this.page.url = window.location.href + "#" + postId;

        }

      });

      const loading = document.getElementById(`loading-${postId}`);
      if (loading) loading.remove();

      comments.dataset.loaded = "true";

    }

  });

});


// ====== READ MORE (fallback JS) ======
function togglePostButton(btn){

  const post = btn.closest('.blog-post');
  if (!post) return;

  const extra = post.querySelector('.extra-content');
  if (!extra) return;

  const checkbox = post.querySelector('.toggle');

  if (checkbox) {

    checkbox.checked = !checkbox.checked;

    const readBtn = post.querySelector('.read-more');

    if (checkbox.checked) {

      readBtn.textContent = "Clique aqui para Fechar";
      readBtn.classList.add("open");

    } else {

      readBtn.textContent = "Leia mais";
      readBtn.classList.remove("open");

    }

    return;
  }

  if (extra.style.display === "block") {

    extra.style.display = "none";

    const readBtn = post.querySelector('.read-more');

    if (readBtn){
      readBtn.textContent = "Leia mais";
      readBtn.classList.remove('open');
    }

  } else {

    extra.style.display = "block";

    const readBtn = post.querySelector('.read-more');

    if (readBtn){
      readBtn.textContent = "Clique aqui para Fechar";
      readBtn.classList.add('open');
    }

  }

}
